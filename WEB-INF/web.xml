<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>Foodie Servlet Site</display-name>

  <!-- Exposes page URLs with a ".jsp" suffix by redirecting extension-less
       page GETs (e.g. /menu -> /menu.jsp). See com.foodie.web.JspUrlFilter. -->
  <filter>
    <filter-name>JspUrlFilter</filter-name>
    <filter-class>com.foodie.web.JspUrlFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>JspUrlFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <servlet>
    <servlet-name>FoodieServlet</servlet-name>
    <servlet-class>com.foodie.web.FoodieServlet</servlet-class>
  </servlet>

  <!-- Each route is mapped both clean (used by form POSTs and internal
       redirects) and with a ".jsp" suffix (what the browser now shows). The
       servlet strips the suffix before routing (FoodieServlet.route). -->

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/home</url-pattern>
    <url-pattern>/home.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/dashboard</url-pattern>
    <url-pattern>/dashboard.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/admin/dashboard</url-pattern>
    <url-pattern>/admin/dashboard.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/admin/users</url-pattern>
    <url-pattern>/admin/users.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/admin/items</url-pattern>
    <url-pattern>/admin/items.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/admin/orders</url-pattern>
    <url-pattern>/admin/orders.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/rider/dashboard</url-pattern>
    <url-pattern>/rider/dashboard.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/rider/orders</url-pattern>
    <url-pattern>/rider/orders.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/menu</url-pattern>
    <url-pattern>/menu.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/cart</url-pattern>
    <url-pattern>/cart.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/checkout</url-pattern>
    <url-pattern>/checkout.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/orders</url-pattern>
    <url-pattern>/orders.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/chat</url-pattern>
    <url-pattern>/chat.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/login</url-pattern>
    <url-pattern>/login.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/signup</url-pattern>
    <url-pattern>/signup.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/forgot-password</url-pattern>
    <url-pattern>/forgot-password.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
    <url-pattern>/logout.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/reservations</url-pattern>
    <url-pattern>/reservations.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/reservations/my</url-pattern>
    <url-pattern>/reservations/my.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/admin/tables</url-pattern>
    <url-pattern>/admin/tables.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/admin/reservations</url-pattern>
    <url-pattern>/admin/reservations.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/complaints</url-pattern>
    <url-pattern>/complaints.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/profile</url-pattern>
    <url-pattern>/profile.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/admin/complaints</url-pattern>
    <url-pattern>/admin/complaints.jsp</url-pattern>
  </servlet-mapping>

  <servlet-mapping>
    <servlet-name>FoodieServlet</servlet-name>
    <url-pattern>/admin/coupons</url-pattern>
    <url-pattern>/admin/coupons.jsp</url-pattern>
  </servlet-mapping>

  <welcome-file-list>
    <welcome-file>home</welcome-file>
  </welcome-file-list>
</web-app>
